{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean&Configure",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/build/* && cmake --preset arm-none-eabi",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "detail": "Löscht den build-Ordner und konfiguriert neu mittels CMake Presets."
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "hide": true,
            "label": "Flash (ST-Link/V2)",
            "type": "shell",
            "command": "cmake --build build --target stlink-flash",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
         {
            "hide": false,
            "label": "Flash (JLink)",
            "type": "shell",
            "command": "cmake --build build --target jlink-flash",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "hide": false,
            "label": "Flash (BMP)",
            "type": "shell",
            "command": "cmake --build build --target bmp-flash",
            "problemMatcher": []
        }

    ]
}